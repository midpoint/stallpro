/* pages/order/detail.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.status-card {
  background: linear-gradient(135deg, #FF6B35 0%, #E55A2B 100%);
  color: white;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.order-number {
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.order-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1px solid #f0f0f0;
}

.order-items {
  margin-bottom: 20rpx;
}

.item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid #f9f9f9;
}

.item:last-child {
  border-bottom: none;
}

.item-name {
  flex: 1;
  font-size: 28rpx;
}

.item-qty {
  color: #666;
  font-size: 28rpx;
  margin-right: 30rpx;
}

.item-price {
  font-size: 28rpx;
  font-weight: 500;
}

.order-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1px solid #f0f0f0;
  font-size: 32rpx;
}

.total-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B35;
}

.tips {
  text-align: center;
  padding: 40rpx;
  color: #666;
  font-size: 28rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.btn-primary {
  background: #FF6B35;
  color: white;
  border-radius: 50rpx;
  font-weight: bold;
}
