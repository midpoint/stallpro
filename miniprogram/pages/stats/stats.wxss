.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

.tab-bar {
  display: flex;
  background: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 16rpx 0;
  position: relative;
}

.tab-item.active {
  color: #FF6B35;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #FF6B35;
  border-radius: 2rpx;
}

.stats-card {
  display: flex;
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B35;
}

.stats-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.stats-divider {
  width: 1rpx;
  background: #eee;
  margin: 0 20rpx;
}

.section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #FF6B35;
}

.trend-chart {
  height: 200rpx;
  position: relative;
}

.trend-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 160rpx;
  padding: 0 10rpx;
}

.trend-bar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.trend-bar {
  width: 30rpx;
  background: linear-gradient(180deg, #FF6B35 0%, #ff9b7a 100%);
  border-radius: 4rpx 4rpx 0 0;
  min-height: 4rpx;
  transition: height 0.3s;
}

.trend-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

.empty-chart, .empty-list {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}

.product-list {
  display: flex;
  flex-direction: column;
}

.product-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.product-item:last-child {
  border-bottom: none;
}

.product-rank {
  width: 40rpx;
  height: 40rpx;
  background: #eee;
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
  color: #666;
  margin-right: 16rpx;
}

.product-rank.top {
  background: #FF6B35;
  color: #fff;
}

.product-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.product-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.product-count {
  font-size: 26rpx;
  color: #999;
  margin-right: 30rpx;
}

.product-revenue {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: bold;
  min-width: 100rpx;
  text-align: right;
}

.peak-list {
  display: flex;
  flex-direction: column;
}

.peak-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  position: relative;
}

.peak-badge {
  background: #FF6B35;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.peak-time {
  font-size: 28rpx;
  color: #333;
  min-width: 160rpx;
}

.peak-count {
  font-size: 26rpx;
  color: #999;
  margin-left: 20rpx;
}

.peak-bar {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  height: 16rpx;
  background: linear-gradient(90deg, #FF6B35 0%, #ff9b7a 100%);
  border-radius: 8rpx;
  opacity: 0.3;
  transition: width 0.3s;
}

.peak-top .peak-bar {
  opacity: 0.6;
}
