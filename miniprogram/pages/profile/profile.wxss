/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #FF6B35 0%, #E55A2B 100%);
  color: white;
  padding: 60rpx 30rpx;
  text-align: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin: 0 auto 16rpx;
  display: block;
  background: rgba(255,255,255,0.3);
  text-align: center;
  font-size: 80rpx;
  line-height: 120rpx;
}

.header image.avatar {
  line-height: normal;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
}

.stall-name {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

/* 今日数据 */
.stats-card {
  display: flex;
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6B35;
}

.stats-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.stats-divider {
  width: 1px;
  background: #eee;
  margin: 0 20rpx;
}

.menu-list {
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1px solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
}

.menu-arrow {
  color: #ccc;
  font-size: 28rpx;
}

.logout-btn {
  margin: 40rpx 20rpx;
  background: white;
  color: #666;
  border-radius: 16rpx;
}
