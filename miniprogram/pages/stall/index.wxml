<!--pages/stall/index.wxml-->
<view class="container">
  <!-- 店铺头部 -->
  <view class="stall-header">
    <view class="stall-info">
      <view class="stall-name">{{stall.name}}</view>
      <view class="stall-notice">{{stall.notice}}</view>
    </view>
    <view class="stall-actions">
      <view class="action-btn" bindtap="showQrcode">📲二维码</view>
      <view class="action-btn primary" bindtap="showPaymentQrcode">💰收款码</view>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stats-item">
      <view class="stats-value">{{stats.orderCount}}</view>
      <view class="stats-label">今日订单</view>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <view class="stats-value">¥{{stats.todayRevenue}}</view>
      <view class="stats-label">今日营收</view>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <view class="stats-value">{{stats.pendingCount}}</view>
      <view class="stats-label">待制作</view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions">
    <view class="quick-action-btn" bindtap="showQrcode">
      <view class="quick-icon">📲</view>
      <view class="quick-text">让顾客扫码点餐</view>
    </view>
    <view class="quick-actions-row">
      <view class="quick-action" bindtap="testOrder">
        <view class="quick-icon">🧪</view>
        <view class="quick-text">测试订单</view>
      </view>
      <view class="quick-action" bindtap="testCall">
        <view class="quick-icon">📢</view>
        <view class="quick-text">测试叫号</view>
      </view>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-section">
    <view class="section-title">
      <text>订单列表</text>
      <text class="order-count" wx:if="{{orders.length > 0}}">{{orders.length}}单</text>
    </view>

    <!-- 待接单订单 -->
    <view class="order-group" wx:if="{{pendingOrders.length > 0}}">
      <view class="group-title">待接单 ({{pendingOrders.length}})</view>
      <block wx:for="{{pendingOrders}}" wx:key="id">
        <view class="order-card pending">
          <view class="order-header">
            <view class="order-number">{{item.orderNumber}}</view>
            <view class="order-time">{{item.createdAt}}</view>
          </view>
          <view class="order-items">
            <block wx:for="{{item.items}}" wx:for-item="food" wx:key="name">
              <view class="order-food">{{food.name}} <text wx:if="{{food.specs}}">({{food.specs}})</text> x{{food.quantity}}</view>
            </block>
          </view>
          <view class="order-footer">
            <view class="order-amount">¥{{item.totalAmount}}</view>
            <view class="order-actions">
              <button size="mini" type="primary" bindtap="acceptOrder" data-id="{{item._id}}">接单</button>
            </view>
          </view>
        </view>
      </block>
    </view>

    <!-- 制作中订单 -->
    <view class="order-group" wx:if="{{cookingOrders.length > 0}}">
      <view class="group-title cooking">制作中 ({{cookingOrders.length}})</view>
      <block wx:for="{{cookingOrders}}" wx:key="id">
        <view class="order-card cooking">
          <view class="order-header">
            <view class="order-number">{{item.orderNumber}}</view>
            <view class="order-time">{{item.createdAt}}</view>
          </view>
          <view class="order-items">
            <block wx:for="{{item.items}}" wx:for-item="food" wx:key="name">
              <view class="order-food">{{food.name}} x{{food.quantity}}</view>
            </block>
          </view>
          <view class="order-footer">
            <view class="order-amount">¥{{item.totalAmount}}</view>
            <view class="order-actions">
              <button size="mini" type="success" bindtap="completeOrder" data-id="{{item._id}}">完成</button>
            </view>
          </view>
        </view>
      </block>
    </view>

    <!-- 已完成订单 -->
    <view class="order-group" wx:if="{{completedOrders.length > 0}}">
      <view class="group-title completed">已完成 ({{completedOrders.length}})</view>
      <block wx:for="{{completedOrders}}" wx:key="id">
        <view class="order-card completed">
          <view class="order-header">
            <view class="order-number">{{item.orderNumber}}</view>
            <view class="order-status done">已完成</view>
          </view>
          <view class="order-items">
            <block wx:for="{{item.items}}" wx:for-item="food" wx:key="name">
              <view class="order-food">{{food.name}} x{{food.quantity}}</view>
            </block>
          </view>
          <view class="order-footer">
            <view class="order-amount">¥{{item.totalAmount}}</view>
            <view class="order-actions">
              <button size="mini" bindtap="callNumber" data-id="{{item._id}}">叫号</button>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="empty" wx:if="{{orders.length === 0}}">
    <view class="empty-icon">📭</view>
    <view>暂无订单</view>
    <view class="empty-tip">扫码点餐功能已在设置中开启</view>
  </view>

  <!-- 二维码弹窗 -->
  <view class="qrcode-modal {{showQrcodeModal ? 'show' : ''}}" bindtap="hideQrcode">
    <view class="qrcode-content" catchtap="stopPropagation">
      <view class="qrcode-title">扫码点餐</view>
      <view class="qrcode-image">
        <image src="{{qrcodeUrl}}" mode="aspectFit" wx:if="{{qrcodeUrl}}" />
        <view class="qrcode-loading" wx:else>加载中...</view>
      </view>
      <view class="qrcode-tip">顾客扫码直接点餐</view>
    </view>
  </view>

  <!-- 收款码弹窗 -->
  <view class="qrcode-modal {{showPaymentModal ? 'show' : ''}}" bindtap="hidePaymentQrcode">
    <view class="qrcode-content" catchtap="stopPropagation">
      <view class="qrcode-header">
        <view class="qrcode-title">收款二维码</view>
        <view class="qrcode-close" bindtap="hidePaymentQrcode">×</view>
      </view>
      <view class="payment-tabs">
        <view class="payment-tab {{paymentTab === 'wechat' ? 'active' : ''}}" bindtap="switchPaymentTab" data-tab="wechat">微信支付</view>
        <view class="payment-tab {{paymentTab === 'alipay' ? 'active' : ''}}" bindtap="switchPaymentTab" data-tab="alipay">支付宝</view>
      </view>
      <view class="payment-body">
        <view wx:if="{{paymentTab === 'wechat'}}" class="payment-section">
          <view class="account-info" wx:if="{{paymentAccounts.wechat.name || paymentAccounts.wechat.account}}">
            <text>收款人：{{paymentAccounts.wechat.name || '未设置'}}</text>
            <text wx:if="{{paymentAccounts.wechat.account}}">账  号：{{paymentAccounts.wechat.account}}</text>
          </view>
          <view class="qrcode-image" wx:if="{{paymentAccounts.wechat.qrcodeUrl}}">
            <image src="{{paymentAccounts.wechat.qrcodeUrl}}" mode="aspectFit" />
          </view>
          <view class="qrcode-placeholder" wx:else>
            <text class="placeholder-icon">💳</text>
            <text class="placeholder-text">暂未设置微信收款码</text>
            <text class="placeholder-tip">请在「收款账户设置」中配置</text>
          </view>
        </view>
        <view wx:if="{{paymentTab === 'alipay'}}" class="payment-section">
          <view class="account-info" wx:if="{{paymentAccounts.alipay.name || paymentAccounts.alipay.account}}">
            <text>收款人：{{paymentAccounts.alipay.name || '未设置'}}</text>
            <text wx:if="{{paymentAccounts.alipay.account}}">账  号：{{paymentAccounts.alipay.account}}</text>
          </view>
          <view class="qrcode-image" wx:if="{{paymentAccounts.alipay.qrcodeUrl}}">
            <image src="{{paymentAccounts.alipay.qrcodeUrl}}" mode="aspectFit" />
          </view>
          <view class="qrcode-placeholder" wx:else>
            <text class="placeholder-icon">💳</text>
            <text class="placeholder-text">暂未设置支付宝收款码</text>
            <text class="placeholder-tip">请在「收款账户设置」中配置</text>
          </view>
        </view>
      </view>
      <view class="qrcode-footer">
        <text>顾客扫码支付，资金直达您的账户</text>
      </view>
    </view>
  </view>
</view>
