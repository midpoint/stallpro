<!--pages/menu/menu.wxml-->
<view class="container">
  <!-- 头部信息 -->
  <view class="header">
    <view class="header-top">
      <view class="stall-name">{{stall.name}}</view>
      <view class="owner-switch" bindtap="switchToOwner">我是摊主</view>
    </view>
    <view class="stall-notice">{{stall.notice}}</view>
  </view>

  <!-- 商品列表 -->
  <view class="menu-list">
    <view class="category-title">📋 菜单</view>
    <block wx:for="{{products}}" wx:key="id">
      <view class="product-item" bindtap="addToCart" data-product="{{item}}">
        <view class="product-icon">{{item.name === '鸡蛋灌饼' ? '🥚' : item.name === '手抓饼' ? '🌭' : item.name === '烤冷面' ? '🍜' : '🌭'}}</view>
        <view class="product-info">
          <view class="product-name">{{item.name}}</view>
          <view class="product-price">¥{{item.price}}</view>
        </view>
        <view class="add-btn">+</view>
      </view>
    </block>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{products.length === 0}}">
    <view>暂无商品</view>
  </view>

  <!-- 购物车栏 -->
  <view class="cart-bar" wx:if="{{cartCount > 0}}" bindtap="showCartPanel">
    <view class="cart-icon">
      🛒
      <view class="cart-badge">{{cartCount}}</view>
    </view>
    <view class="cart-total">¥{{cartTotal}}</view>
    <view class="checkout-btn" bindtap="checkout">去支付</view>
  </view>

  <!-- 购物车弹窗 -->
  <view class="cart-overlay {{showCart ? 'show' : ''}}" bindtap="hideCartPanel">
    <view class="cart-panel" catchtap="stopPropagation">
      <view class="cart-header">
        <view class="cart-title">购物车</view>
        <view class="clear-btn" bindtap="clearCart">清空</view>
      </view>

      <scroll-view scroll-y class="cart-items">
        <block wx:for="{{cart}}" wx:key="id">
          <view class="cart-item">
            <view class="item-info">
              <view class="item-name">{{item.name}}</view>
              <view class="item-price">¥{{item.price}}</view>
            </view>
            <view class="item-actions">
              <view class="action-btn minus" bindtap="reduceCart" data-id="{{item.id}}">-</view>
              <view class="item-qty">{{item.quantity}}</view>
              <view class="action-btn plus" bindtap="addCart" data-id="{{item.id}}">+</view>
            </view>
          </view>
        </block>
      </scroll-view>

      <view class="cart-footer">
        <view class="total-label">合计</view>
        <view class="total-price">¥{{cartTotal}}</view>
        <button class="pay-btn" bindtap="checkout">微信支付</button>
      </view>
    </view>
  </view>
</view>
