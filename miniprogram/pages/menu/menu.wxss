/* pages/menu/menu.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #FF6B35 0%, #E55A2B 100%);
  color: white;
  padding: 30rpx;
  text-align: center;
}

.stall-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.stall-notice {
  font-size: 26rpx;
  opacity: 0.9;
}

.menu-list {
  padding: 20rpx;
}

.category-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.product-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.product-icon {
  font-size: 50rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f9f9f9;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.product-price {
  color: #FF6B35;
  font-size: 32rpx;
  font-weight: bold;
}

.add-btn {
  width: 60rpx;
  height: 60rpx;
  background: #FF6B35;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
}

.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #333;
  color: white;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.cart-icon {
  font-size: 44rpx;
  position: relative;
  margin-right: 20rpx;
}

.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -15rpx;
  background: #FF6B35;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.cart-total {
  flex: 1;
  font-size: 36rpx;
  font-weight: bold;
}

.checkout-btn {
  background: #FF6B35;
  color: white;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 购物车弹窗 */
.cart-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.cart-overlay.show {
  opacity: 1;
  visibility: visible;
}

.cart-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.cart-overlay.show .cart-panel {
  transform: translateY(0);
}

.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1px solid #f0f0f0;
}

.cart-title {
  font-size: 32rpx;
  font-weight: bold;
}

.clear-btn {
  color: #FF6B35;
  font-size: 28rpx;
}

.cart-items {
  flex: 1;
  overflow-y: auto;
  padding: 0 30rpx;
}

.cart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid #f9f9f9;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.item-price {
  color: #FF6B35;
  font-size: 28rpx;
}

.item-actions {
  display: flex;
  align-items: center;
}

.action-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.action-btn.minus {
  background: #f0f0f0;
  color: #666;
}

.action-btn.plus {
  background: #FF6B35;
  color: white;
}

.item-qty {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
}

.cart-footer {
  display: flex;
  align-items: center;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  border-top: 1px solid #f0f0f0;
}

.total-label {
  font-size: 28rpx;
  color: #666;
}

.total-price {
  flex: 1;
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B35;
  margin-left: 20rpx;
}

.pay-btn {
  background: #07C160;
  color: white;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  padding: 20rpx 60rpx;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
}
