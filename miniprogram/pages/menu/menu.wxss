/* pages/menu/menu.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 100rpx;
}

.header {
  background: linear-gradient(135deg, #FF6B35 0%, #E55A2B 100%);
  color: white;
  padding: 30rpx;
  text-align: center;
}

.stall-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.stall-notice {
  font-size: 26rpx;
  opacity: 0.9;
}

.menu-list {
  padding: 20rpx;
}

.category-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.product-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.product-icon {
  font-size: 50rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f9f9f9;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.product-price {
  color: #FF6B35;
  font-size: 32rpx;
  font-weight: bold;
}

.add-btn {
  width: 60rpx;
  height: 60rpx;
  background: #FF6B35;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
}

.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #333;
  color: white;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.cart-icon {
  font-size: 44rpx;
  position: relative;
  margin-right: 20rpx;
}

.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -15rpx;
  background: #FF6B35;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.cart-total {
  flex: 1;
  font-size: 36rpx;
  font-weight: bold;
}

.checkout-btn {
  background: #FF6B35;
  color: white;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
}
