/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FF6B35 0%, #E55A2B 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.logo {
  font-size: 160rpx;
  margin-bottom: 40rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 120rpx;
}

.login-btn {
  width: 80%;
  background: white;
  color: #FF6B35;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  padding: 26rpx 0;
  border: none;
}

.login-btn:active {
  opacity: 0.9;
}

.tips {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
