/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FF6B35 0%, #E55A2B 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.logo {
  font-size: 140rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 60rpx;
}

.owner-section, .customer-section {
  width: 100%;
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

.login-btn {
  width: 100%;
  background: #FF6B35;
  color: white;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  padding: 24rpx 0;
  border: none;
}

.login-btn:active {
  opacity: 0.9;
}

.tips {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 16rpx;
}

.customer-tip {
  text-align: center;
  margin-bottom: 24rpx;
}

.customer-tip view:first-child {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
}

.guest-btn {
  width: 100%;
  background: white;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  padding: 24rpx 0;
}

.guest-btn:active {
  background: #FFF7E6;
}
