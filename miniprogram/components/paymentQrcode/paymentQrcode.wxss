.qrcode-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: none;
  justify-content: center;
  align-items: center;
}

.qrcode-modal.show {
  display: flex;
}

.qrcode-content {
  background: #fff;
  border-radius: 24rpx;
  width: 600rpx;
  max-width: 90vw;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.qrcode-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.qrcode-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.qrcode-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.qrcode-tabs {
  display: flex;
  border-bottom: 1rpx solid #eee;
}

.qrcode-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.qrcode-tab.active {
  color: #FF6B35;
  font-weight: bold;
}

.qrcode-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #FF6B35;
  border-radius: 2rpx;
}

.qrcode-body {
  padding: 40rpx 30rpx;
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.account-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 30rpx;
  width: 100%;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.qrcode-image {
  width: 350rpx;
  height: 350rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  padding: 20rpx;
}

.qrcode-image image {
  width: 100%;
  height: 100%;
}

.qrcode-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.placeholder-tip {
  font-size: 24rpx;
  color: #999;
}

.qrcode-footer {
  padding: 20rpx 30rpx;
  background: #f9f9f9;
  text-align: center;
}

.qrcode-footer text {
  font-size: 24rpx;
  color: #999;
}
